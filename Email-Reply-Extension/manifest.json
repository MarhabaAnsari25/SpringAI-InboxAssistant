{
    "name": "Email Reply Assistant",
    "description": "AI-powered email reply generator using your local Spring Boot backend",
    "version": "1.0",
    "manifest_version": 3,

    "permissions": ["activeTab", "storage"],

    "host_permissions": [
        "http://localhost:9191/*",
        "*://mail.google.com/*"
    ],

    "content_scripts": [
        {
            "matches": ["*://mail.google.com/*"],
            "js": ["content.js"],
            "css": ["content.css"],
            "run_at": "document_end"
        }
    ],

    "web_accessible_resources": [
        {
            "resources": ["Icon.png"],
            "matches": ["*://mail.google.com/*"]
        }
    ],

    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://localhost:9191"
    },

    "action": {
        "default_title": "Email Reply Assistant",
        "default_popup": "popup.html",
        "default_icon": "Icon.png"
    }
}
